{
  "name": "loteria-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "bot:dev": "cd telegram-bot && npm run dev",
    "bot:build": "cd telegram-bot && npm run build",
    "bot:start": "cd telegram-bot && npm start",
    "dev:all": "concurrently \"npm run dev\" \"npm run bot:dev\"",
    "build:all": "npm run build && npm run bot:build"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "lucide-react": "^1.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.22.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.57.1",
    "vite": "^6.0.7"
  }
}
